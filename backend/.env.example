# 服务器配置
SERVER_PORT=8081
SERVER_HOST=0.0.0.0
GIN_MODE=debug

# 数据库配置
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=smartcam
DB_USER=smartcam
DB_PASSWORD=smartcam_dev_pass

# Redis 配置
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# ZLMediaKit 配置
ZLM_API_URL=http://127.0.0.1:8081
ZLM_SECRET=035c73f7-bb6f-4a59-abf7-3a47ddf33d0e
ZLM_ENABLED=false

# JWT 配置
JWT_SECRET=your-super-secret-key-change-in-production

# 日志配置
LOG_LEVEL=info
LOG_FORMAT=json

# 播放配置
PLAY_SESSION_TIMEOUT_SECONDS=3600
MAX_CONCURRENT_STREAMS_PER_USER=4
MAX_CONCURRENT_STREAMS_PER_PROPERTY=50
STREAM_IDLE_TIMEOUT_SECONDS=30
