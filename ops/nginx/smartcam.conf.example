# SmartCam Nginx 反向代理配置
# 
# 使用方法：
# 1. 复制本文件到 /etc/nginx/sites-available/smartcam
# 2. 创建符号链接：ln -s /etc/nginx/sites-available/smartcam /etc/nginx/sites-enabled/smartcam
# 3. 测试配置：nginx -t
# 4. 重载配置：systemctl reload nginx

upstream backend {
    server 127.0.0.1:8081;
    keepalive 32;
}

upstream frontend {
    server 127.0.0.1:5173;
    keepalive 32;
}

upstream stream_server {
    server 127.0.0.1:8080;
    keepalive 32;
}

server {
    listen 80;
    listen [::]:80;
    server_name smartcam.example.com;

    # HTTP 重定向到 HTTPS（可选）
    # return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name smartcam.example.com;

    # SSL 证书配置（需要替换为实际路径）
    # ssl_certificate /etc/letsencrypt/live/smartcam.example.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/smartcam.example.com/privkey.pem;

    # 基本安全配置
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    # 日志
    access_log /var/log/nginx/smartcam-access.log combined;
    error_log /var/log/nginx/smartcam-error.log warn;

    # 请求体大小限制
    client_max_body_size 100M;

    # 前端：React SPA
    location / {
        proxy_pass http://frontend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # SPA 路由重写
        error_page 404 =200 /index.html;
    }

    # 后端 API
    location /api/ {
        proxy_pass http://backend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # WebSocket 支持（如果需要）
        proxy_read_timeout 86400;
        proxy_connect_timeout 7d;
    }

    # 流媒体服务
    location /stream/ {
        proxy_pass http://stream_server;
        proxy_http_version 1.1;
        proxy_buffering off;
        proxy_set_header Connection "";
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

        # 流媒体特定设置
        proxy_read_timeout 3600;
        proxy_request_buffering off;
    }

    # 健康检查
    location /health {
        access_log off;
        return 200 "healthy\n";
        add_header Content-Type text/plain;
    }

    # 禁用不必要的请求方法
    if ($request_method !~ ^(GET|HEAD|POST|PUT|DELETE|OPTIONS|PATCH)$) {
        return 405;
    }

    # 安全头部
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "no-referrer-when-downgrade" always;
}
